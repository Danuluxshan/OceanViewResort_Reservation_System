<h2>My Profile</h2>

<div class="form-card">

    <label>Full Name</label>
    <input type="text" value="${sessionScope.fullName}" readonly>

    <label>Username</label>
    <input type="text" value="${sessionScope.username}" readonly>

    <label>Email</label>
    <input type="text" value="${sessionScope.email}" readonly>

    <label>Contact</label>
    <input type="text" value="${sessionScope.contact}" readonly>

    <label>Address</label>
    <input type="text" value="${sessionScope.address}" readonly>

</div>